# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEYS=key1,key2,key3

# ── LinkedIn cookie auth ─────────────────────────────────────────────────────
LINKEDIN_LI_AT=your-li_at-cookie
LINKEDIN_JSESSIONID=your-jsessionid-cookie

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=your-sheet-id
GOOGLE_CREDENTIALS_PATH=credentials/google-sheets.json

# ── Proxies (optional) ───────────────────────────────────────────────────────
# PROXIES=http://user:pass@host:port,http://user:pass@host2:port2
