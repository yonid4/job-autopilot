# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret  # Dashboard → Settings → API → JWT Secret

# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
# Optional: comma-separated list of keys to rotate through when one hits quota
GEMINI_API_KEYS=key1,key2,key3
# Models (override to switch, e.g. gemini-2.0-flash, gemini-1.5-flash)
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# ── LinkedIn cookie auth ─────────────────────────────────────────────────────
# Get these from your browser cookies at linkedin.com (DevTools → Application → Cookies)
LINKEDIN_LI_AT=your-li_at-cookie
LINKEDIN_JSESSIONID=your-jsessionid-cookie

# ── Google Sheets (legacy CLI only) ──────────────────────────────────────────
GOOGLE_SHEET_ID=your-sheet-id
GOOGLE_CREDENTIALS_PATH=credentials/google-sheets.json

# ── Proxies (optional) ───────────────────────────────────────────────────────
# PROXIES=http://user:pass@host:port,http://user:pass@host2:port2
